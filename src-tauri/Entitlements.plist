<?xml version="1.0" encoding="UTF-8"?>
<!--
  Code-signing entitlements for the macOS bundle. The microphone entitlement is
  what lets a hardened-runtime / notarized build reach the mic for the voice
  agent's push-to-talk dictation (`src/dictation.rs`); without it a hardened
  build is killed by the runtime when AVAudioEngine touches input. A locally
  self-signed "Redline Dev" build without hardened runtime doesn't strictly
  require it, but keeping it here is forward-looking for the signed public DMG
  and harmless to the dev signing flow (see scripts/redline.sh).
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
